# Local broker (Pi): Jetson publishes vision here, Pi subscribes
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=fire_pi_01

# Cloud broker (AWS): Pi publishes events/status here for the dashboard
# Leave blank to disable cloud publishing
MQTT_CLOUD_BROKER=
MQTT_CLOUD_PORT=1883
MQTT_CLOUD_CLIENT_ID=fire_pi_01_cloud

# Base topic
MQTT_BASE_TOPIC=fire_detection

# Optional override (leave commented if using BASE)
# MQTT_TOPIC_EVENTS=fire_detection/events
# MQTT_TOPIC_STATUS=fire_detection/status

# RFID CONFIGURATION
# Comma-separated list of authorised card IDs
AUTHORISED_CARDS=12345678

# SIMULATION CONFIGURATION
SIM_FLAG_FILE=/tmp/fire_sim_flags.json